{% assign relaunch_mode = true %}

<header class="site-header{% if relaunch_mode %} site-header--relaunch{% endif %}">
  <div class="container header-inner">
    {% unless relaunch_mode %}
      <button
        class="icon-button mobile-menu-button"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="MobileMenu"
        data-menu-toggle
      >
        {% render 'icon-menu' %}
      </button>
    {% endunless %}

    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }} home">
      {% unless relaunch_mode %}
        {% if section.settings.logo != blank %}
          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag:
              class: 'brand-logo',
              widths: '120, 180, 240, 320',
              width: section.settings.logo_width,
              loading: 'eager',
              alt: shop.name
          }}
        {% else %}
          <img
            class="brand-logo brand-logo--default"
            src="{{ 'zero-credit-logo-black.png' | asset_url }}"
            width="{{ section.settings.logo_width }}"
            height="{{ section.settings.logo_width }}"
            alt="{{ shop.name | escape }}"
            loading="eager"
          >
        {% endif %}
      {% endunless %}
      {% if section.settings.show_brand_name %}
        <span class="brand-name brand-name--desktop">{{ section.settings.brand_name | escape }}</span>
        <span class="brand-name brand-name--mobile">{{ section.settings.compact_brand_name | escape }}</span>
      {% endif %}
    </a>

    {% unless relaunch_mode %}
      <nav class="desktop-nav" aria-label="Primary navigation">
        <ul>
          {% for link in section.settings.menu.links %}
            <li>
              <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endunless %}

    {% unless relaunch_mode %}
      <div class="header-actions">
        <a class="icon-button" href="{{ routes.search_url }}" aria-label="Search">
          {% render 'icon-search' %}
        </a>
        {% if shop.customer_accounts_enabled %}
          <a class="icon-button account-link" href="{{ routes.account_url }}" aria-label="Account">
            {% render 'icon-account' %}
          </a>
        {% endif %}
        <a
          class="icon-button cart-button"
          href="{{ routes.cart_url }}"
          aria-label="Open cart"
          aria-controls="CartDrawer"
          aria-expanded="false"
          data-cart-open
        >
          {% render 'icon-cart' %}
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
    {% endunless %}
  </div>

  {% unless relaunch_mode %}
    <div class="menu-backdrop" aria-hidden="true" data-menu-backdrop></div>
    <div
      id="MobileMenu"
      class="mobile-menu"
      aria-label="Navigation menu"
      aria-hidden="true"
      aria-modal="true"
      role="dialog"
      data-mobile-menu
    >
      <div class="mobile-menu-header">
        <span>{{ section.settings.compact_brand_name | escape }}</span>
        <button class="icon-button" type="button" aria-label="Close menu" data-menu-close>
          {% render 'icon-close' %}
        </button>
      </div>
      <nav class="mobile-menu-body" aria-label="Mobile navigation">
        <ul>
          {% for link in section.settings.menu.links %}
            <li>
              <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>
                <span>0{{ forloop.index }}</span>
                {{ link.title | escape }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </div>
  {% endunless %}
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo mark width",
      "min": 40,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "checkbox",
      "id": "show_brand_name",
      "label": "Show brand name beside logo",
      "default": true
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Desktop brand name",
      "default": "The Zero Credit Project"
    },
    {
      "type": "text",
      "id": "compact_brand_name",
      "label": "Mobile compact brand name",
      "default": "The Zero Credit Project"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
