<header class="site-header">
  <div class="container header-inner">
    <button
      class="icon-button mobile-menu-button"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="MobileMenu"
      data-menu-toggle
    >
      {% render 'icon-menu' %}
    </button>

    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }} home">
      {% if section.settings.logo != blank %}
        {{
          section.settings.logo
          | image_url: width: section.settings.logo_width
          | image_tag:
            class: 'brand-logo',
            widths: '120, 180, 240, 320',
            width: section.settings.logo_width,
            loading: 'eager',
            alt: shop.name
        }}
      {% else %}
        <img
          class="brand-logo"
          src="{{ 'zero-credit-logo-black.png' | asset_url }}"
          width="{{ section.settings.logo_width }}"
          height="{{ section.settings.logo_width }}"
          alt="{{ shop.name | escape }}"
          loading="eager"
        >
      {% endif %}
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      <ul>
        {% for link in section.settings.menu.links %}
          <li>
            <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="header-actions">
      {% if shop.customer_accounts_enabled %}
        <a class="icon-button account-link" href="{{ routes.account_url }}" aria-label="Account">
          {% render 'icon-account' %}
        </a>
      {% endif %}
      <a class="icon-button cart-button" href="{{ routes.cart_url }}" aria-label="Open cart" data-cart-open>
        {% render 'icon-cart' %}
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  <nav id="MobileMenu" class="mobile-menu" aria-label="Mobile navigation" hidden data-mobile-menu>
    <ul>
      {% for link in section.settings.menu.links %}
        <li>
          <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 56,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
