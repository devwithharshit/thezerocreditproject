<section class="zc-hero" data-hero>
  <div class="zc-hero__background" aria-hidden="true">
    <div class="zc-hero__outline" data-parallax data-speed="0.08">
      {{ section.settings.background_text | escape }}
    </div>
    <div class="zc-hero__solid" data-parallax data-speed="-0.05">
      {{ section.settings.background_text | escape }}
    </div>
  </div>

  <div class="zc-hero__media" data-reveal="clip">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1800
        | image_tag:
          widths: '600, 900, 1200, 1500, 1800',
          sizes: '(min-width: 990px) 48vw, 88vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.image.alt
      }}
    {% else %}
      <div class="zc-hero__logo-stage">
        <div class="zc-hero__orbit"></div>
        <img
          src="{{ 'zero-credit-logo-white.png' | asset_url }}"
          width="760"
          height="760"
          alt="The Zero Credit Project"
          loading="eager"
        >
      </div>
    {% endif %}
  </div>

  <div class="container zc-hero__content">
    <div class="zc-hero__copy">
      <p class="eyebrow" data-reveal>{{ section.settings.eyebrow | escape }}</p>
      <h1 data-reveal data-delay="100">
        {% assign heading_words = section.settings.heading | split: ' ' %}
        {% for word in heading_words %}
          <span>{{ word | escape }}</span>
        {% endfor %}
      </h1>
      <p class="zc-hero__description" data-reveal data-delay="180">
        {{ section.settings.subheading | escape }}
      </p>
      <div class="button-row" data-reveal data-delay="240">
        {% if section.settings.primary_label != blank %}
          <a class="button button-light button-arrow" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
            <span>{{ section.settings.primary_label | escape }}</span>
            <span aria-hidden="true">↗</span>
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="button button-outline-light" href="{{ section.settings.secondary_link | default: '/collections' }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="zc-hero__index" aria-hidden="true">
    <span>01</span>
    <span class="zc-hero__index-line"></span>
    <span>ZCP / {{ 'now' | date: '%Y' }}</span>
  </div>

  <a class="zc-hero__scroll" href="#shopify-section-{{ section.id }}-after" aria-label="Scroll to next section">
    <span>Scroll</span>
    <span aria-hidden="true">↓</span>
  </a>
</section>
<span id="shopify-section-{{ section.id }}-after"></span>

{% schema %}
{
  "name": "Zero Credit hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Campaign image"
    },
    {
      "type": "text",
      "id": "background_text",
      "label": "Large background text",
      "default": "ZERO CREDIT"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Independent streetwear / India"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built From Zero"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "No credit. No shortcuts. Just the project."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop the Drop"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Zero Credit hero"
    }
  ]
}
{% endschema %}
