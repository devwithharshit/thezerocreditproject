<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand" data-reveal>
      <p class="footer-wordmark">{{ shop.name | escape }}</p>
      <p>{{ section.settings.tagline | escape }}</p>
    </div>

    {% for block in section.blocks %}
      <nav
        class="footer-menu"
        aria-label="{{ block.settings.heading | escape }}"
        data-reveal
        data-delay="{{ forloop.index | times: 70 }}"
        {{ block.shopify_attributes }}
      >
        <h2>{{ block.settings.heading | escape }}</h2>
        <ul>
          {% for link in block.settings.menu.links %}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    {% endfor %}

    <div class="footer-contact" data-reveal data-delay="180">
      <h2>Contact</h2>
      <a href="mailto:{{ section.settings.email | escape }}">{{ section.settings.email | escape }}</a>
      <p>{{ section.settings.address | escape }}</p>
      <p>{{ section.settings.hours | escape }}</p>
    </div>
  </div>

  <div class="container footer-bottom" data-reveal data-delay="230">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}</p>
    <div class="policy-links">
      {% for policy in shop.policies %}
        {% if policy != blank %}
          <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "No credit. No shortcuts. Just the project."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "thezerocreditproject@gmail.com"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Bengaluru, Karnataka, India"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Business hours",
      "default": "Thursday - Sunday, 10:00 AM - 6:00 PM IST"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Explore"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ]
}
{% endschema %}
