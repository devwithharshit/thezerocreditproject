<div class="drawer-backdrop" hidden data-cart-backdrop></div>
<aside
  id="CartDrawer"
  class="cart-drawer"
  aria-label="Shopping cart"
  aria-hidden="true"
  tabindex="-1"
  data-cart-drawer
>
  <div class="cart-drawer-header">
    <h2>{{ section.settings.heading | escape }} ({{ cart.item_count }})</h2>
    <button class="icon-button" type="button" aria-label="Close cart" data-cart-close>
      {% render 'icon-close' %}
    </button>
  </div>

  {% if cart == empty %}
    <div class="cart-empty">
      <p>Your cart is empty.</p>
      <a class="button button-dark" href="{{ routes.all_products_collection_url }}">Shop all</a>
    </div>
  {% else %}
    <div class="cart-items">
      {% for item in cart.items %}
        <div class="cart-item">
          {% if item.image %}
            <a href="{{ item.url }}">
              {{
                item.image
                | image_url: width: 180
                | image_tag: width: 90, loading: 'lazy', alt: item.image.alt
              }}
            </a>
          {% endif %}
          <div>
            <a href="{{ item.url }}">{{ item.product.title | escape }}</a>
            {% unless item.product.has_only_default_variant %}
              <p>{{ item.variant.title | escape }}</p>
            {% endunless %}
            <p>{{ item.quantity }} &times; {{ item.final_price | money }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="cart-drawer-footer">
      <p><span>Subtotal</span><strong>{{ cart.total_price | money }}</strong></p>
      <a class="button button-outline-dark" href="{{ routes.cart_url }}">View cart</a>
      <form action="{{ routes.cart_url }}" method="post">
        <button class="button button-dark" type="submit" name="checkout">Checkout</button>
      </form>
    </div>
  {% endif %}
</aside>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart"
    }
  ]
}
{% endschema %}
