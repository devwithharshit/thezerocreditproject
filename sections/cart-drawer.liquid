<div class="drawer-backdrop" aria-hidden="true" data-cart-backdrop></div>
<aside
  id="CartDrawer"
  class="cart-drawer"
  aria-label="Shopping cart"
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
  tabindex="-1"
  data-cart-drawer
>
  <div class="cart-drawer-header">
    <div>
      <p class="eyebrow">Your selection</p>
      <h2>{{ section.settings.heading | escape }} <span>({{ cart.item_count }})</span></h2>
    </div>
    <button class="icon-button" type="button" aria-label="Close cart" data-cart-close>
      {% render 'icon-close' %}
    </button>
  </div>

  {% if cart == empty %}
    <div class="cart-empty">
      <div class="cart-empty__mark" aria-hidden="true">0</div>
      <h3>Your cart is empty</h3>
      <p>Start with the current drop or explore every piece in the project.</p>
      <a class="button button-dark button-arrow" href="{{ routes.all_products_collection_url }}">
        <span>Shop all</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  {% else %}
    <div class="cart-items">
      {% for item in cart.items %}
        <div class="cart-item">
          {% if item.image %}
            <a href="{{ item.url }}">
              {{
                item.image
                | image_url: width: 180
                | image_tag: width: 90, loading: 'lazy', alt: item.image.alt
              }}
            </a>
          {% endif %}
          <div class="cart-item__details">
            <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title | escape }}</a>
            {% unless item.product.has_only_default_variant %}
              <p class="cart-item__variant">{{ item.variant.title | escape }}</p>
            {% endunless %}
            <div class="cart-item__meta">
              <span>Qty {{ item.quantity }}</span>
              <strong>{{ item.final_line_price | money }}</strong>
            </div>
            <a class="cart-item__remove" href="{{ item.url_to_remove }}">Remove</a>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="cart-drawer-footer">
      <div class="cart-drawer-note" role="status">
        <span aria-hidden="true">✓</span>
        <p>Added to your selection. Keep exploring or review the full cart.</p>
      </div>
      <p><span>Subtotal</span><strong>{{ cart.total_price | money }}</strong></p>
      <small>Shipping and taxes are calculated at checkout.</small>
      <div class="cart-drawer-actions">
        <button class="button button-outline-dark" type="button" data-cart-close>Continue shopping</button>
        <a class="button button-dark" href="{{ routes.cart_url }}">View full cart</a>
      </div>
      <form action="{{ routes.cart_url }}" method="post">
        <button class="cart-drawer-checkout" type="submit" name="checkout">
          Checkout now <span aria-hidden="true">↗</span>
        </button>
      </form>
    </div>
  {% endif %}
</aside>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart"
    }
  ]
}
{% endschema %}
