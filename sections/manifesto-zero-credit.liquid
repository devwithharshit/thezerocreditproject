<section class="manifesto-section">
  <div class="container manifesto-inner">
    <div class="manifesto-mark" data-reveal>
      <span>The</span>
      <strong>Zero Credit</strong>
      <span>Project</span>
    </div>
    <div class="manifesto-copy">
      <p class="eyebrow" data-reveal>{{ section.settings.eyebrow | escape }}</p>
      <h2 data-reveal data-delay="80">{{ section.settings.heading | escape }}</h2>
      <p data-reveal data-delay="160">{{ section.settings.text | escape }}</p>
      <ul class="manifesto-features" data-reveal data-delay="220">
        {% for index in (1..3) %}
          {% case index %}
            {% when 1 %}
              {% assign feature = section.settings.feature_one %}
            {% when 2 %}
              {% assign feature = section.settings.feature_two %}
            {% when 3 %}
              {% assign feature = section.settings.feature_three %}
          {% endcase %}
          {% if feature != blank %}
            <li>
              <span aria-hidden="true">—</span>
              <strong>{{ feature | escape }}</strong>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand manifesto",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Designed with intent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for the everyday project"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Focused streetwear with clean silhouettes, wearable details and a direct shopping experience."
    },
    {
      "type": "text",
      "id": "feature_one",
      "label": "Feature one",
      "default": "Limited-run collections"
    },
    {
      "type": "text",
      "id": "feature_two",
      "label": "Feature two",
      "default": "Made for everyday wear"
    },
    {
      "type": "text",
      "id": "feature_three",
      "label": "Feature three",
      "default": "Secure checkout"
    }
  ],
  "presets": [
    {
      "name": "Brand manifesto"
    }
  ]
}
{% endschema %}
