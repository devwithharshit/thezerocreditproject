<section class="manifesto-section">
  <div class="container manifesto-inner">
    <div class="manifesto-mark" data-reveal="scale">
      <img src="{{ 'zero-credit-logo-white.png' | asset_url }}" width="600" height="600" alt="" loading="lazy">
    </div>
    <div class="manifesto-copy">
      <p class="eyebrow" data-reveal>{{ section.settings.eyebrow | escape }}</p>
      <h2 data-reveal data-delay="80">{{ section.settings.heading | escape }}</h2>
      <p data-reveal data-delay="160">{{ section.settings.text | escape }}</p>
      {% if section.settings.button_label != blank %}
        <a class="button button-light button-arrow" href="{{ section.settings.button_link | default: '/pages/about' }}" data-reveal data-delay="220">
          <span>{{ section.settings.button_label | escape }}</span>
          <span aria-hidden="true">↗</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand manifesto",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The project / 001"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nothing Was Handed To Us"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The Zero Credit Project is for people building identity, momentum and culture from the ground up. Every piece starts with intent."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read our story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand manifesto"
    }
  ]
}
{% endschema %}
