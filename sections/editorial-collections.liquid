<section class="editorial-collections section-spacing">
  <div class="container">
    <header class="editorial-heading" data-reveal>
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
      {% if section.settings.link_label != blank %}
        <a class="text-link text-link--arrow" href="{{ section.settings.link | default: '/collections' }}">
          {{ section.settings.link_label | escape }} <span aria-hidden="true">↗</span>
        </a>
      {% endif %}
    </header>

    <div class="editorial-grid editorial-grid--{{ section.blocks.size }}">
      {% for block in section.blocks %}
        {% assign card_collection = block.settings.collection %}
        {% if card_collection != blank %}
          {% assign card_image = block.settings.image | default: card_collection.image %}
          {% if card_image == blank and card_collection.products.first.featured_image != blank %}
            {% assign card_image = card_collection.products.first.featured_image %}
          {% endif %}
          <a
            class="editorial-card editorial-card--{{ forloop.index }}"
            href="{{ card_collection.url }}"
            data-reveal="clip"
            data-delay="{{ forloop.index | times: 50 }}"
            {{ block.shopify_attributes }}
          >
            <div class="editorial-card__media">
              {% if card_image != blank %}
                {{
                  card_image
                  | image_url: width: 1400
                  | image_tag:
                    widths: '480, 720, 960, 1200, 1400',
                    sizes: '(min-width: 990px) 50vw, 100vw',
                    loading: 'lazy',
                    alt: card_collection.title
                }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="editorial-card__caption">
              <p>{{ block.settings.kicker | escape }}</p>
              <h3>{{ block.settings.heading | default: card_collection.title | escape }}</h3>
              <span>Shop collection <span aria-hidden="true">↗</span></span>
            </div>
          </a>
        {% elsif request.design_mode %}
          <div class="editor-note" {{ block.shopify_attributes }}>Select a real collection for this card.</div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial collections",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore / Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose Your Uniform"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Small text",
          "default": "The first drop"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Custom heading",
          "info": "Leave blank to use the collection title."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial collections",
      "blocks": [
        { "type": "collection", "settings": { "kicker": "Current drop" } },
        { "type": "collection", "settings": { "kicker": "The first chapter" } }
      ]
    }
  ]
}
{% endschema %}
