<section class="editorial-collections section-spacing">
  <div class="container">
    <header class="editorial-heading" data-reveal>
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
      {% if section.settings.link_label != blank %}
        <a class="text-link text-link--arrow" href="{{ section.settings.link | default: '/collections' }}">
          {{ section.settings.link_label | escape }} <span aria-hidden="true">↗</span>
        </a>
      {% endif %}
    </header>

    <div class="editorial-grid">
      {% for block in section.blocks %}
        {% assign card_collection = block.settings.collection %}
        <a
          class="editorial-card editorial-card--{{ forloop.index }}"
          href="{{ card_collection.url | default: block.settings.link | default: '/collections' }}"
          data-reveal="clip"
          data-delay="{{ forloop.index | times: 90 }}"
          {{ block.shopify_attributes }}
        >
          <div class="editorial-card__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  widths: '480, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, 85vw',
                  loading: 'lazy',
                  alt: block.settings.image.alt
              }}
            {% elsif card_collection.featured_image != blank %}
              {{
                card_collection.featured_image
                | image_url: width: 1200
                | image_tag:
                  widths: '480, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, 85vw',
                  loading: 'lazy',
                  alt: card_collection.title
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="editorial-card__number">0{{ forloop.index }}</div>
          <div class="editorial-card__caption">
            <p>{{ block.settings.kicker | escape }}</p>
            <h3>{{ block.settings.heading | default: card_collection.title | escape }}</h3>
            <span>Discover <span aria-hidden="true">↗</span></span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial collections",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore / Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose Your Uniform"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Small text",
          "default": "The first drop"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Street Essentials"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial collections",
      "blocks": [
        { "type": "collection", "settings": { "heading": "Street Essentials", "kicker": "The uniform" } },
        { "type": "collection", "settings": { "heading": "Heavyweight Layers", "kicker": "Built to last" } },
        { "type": "collection", "settings": { "heading": "Limited Objects", "kicker": "Small batch" } }
      ]
    }
  ]
}
{% endschema %}
