{% if section.settings.show_announcement and section.settings.text != blank %}
  <aside
    class="announcement-bar"
    aria-label="Announcement"
    style="--announcement-background: {{ section.settings.background }}; --announcement-text: {{ section.settings.text_color }};"
  >
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}">{{ section.settings.text | escape }}</a>
    {% else %}
      <p>{{ section.settings.text | escape }}</p>
    {% endif %}
  </aside>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Made to order. Built from zero."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
