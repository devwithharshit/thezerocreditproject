{% if section.settings.show_announcement and section.settings.text != blank %}
  {% assign secondary_text = section.settings.secondary_text | default: 'PAN INDIA SHIPPING | GET 10% OFF: CODE ZCPOFF10' %}
  <aside
    class="announcement-bar"
    aria-label="{{ section.settings.text | append: '. ' | append: secondary_text | escape }}"
    style="--announcement-background: {{ section.settings.background }}; --announcement-text: {{ section.settings.text_color }}; --announcement-duration: {{ section.settings.speed }}s;"
  >
    <div class="announcement-bar__viewport">
      <div class="announcement-bar__track{% if section.settings.animate %} is-animated{% endif %}">
        {% for repeat in (1..8) %}
          {% assign alternating_message = repeat | modulo: 2 %}
          {% if alternating_message == 0 %}
            {% assign announcement_text = secondary_text %}
          {% else %}
            {% assign announcement_text = section.settings.text %}
          {% endif %}
          <div class="announcement-bar__item" aria-hidden="true">
            {% if section.settings.link != blank %}
              <a href="{{ section.settings.link }}">{{ announcement_text | escape }}</a>
            {% else %}
              <span>{{ announcement_text | escape }}</span>
            {% endif %}
            <span class="announcement-bar__dot" aria-hidden="true"></span>
          </div>
        {% endfor %}
      </div>
    </div>
  </aside>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Made to order. Built from zero."
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Alternate text",
      "default": "PAN INDIA SHIPPING | GET 10% OFF: CODE ZCPOFF10"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "animate",
      "label": "Animate announcement",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation speed",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 45
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
