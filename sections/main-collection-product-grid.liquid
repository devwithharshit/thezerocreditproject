<section class="section-spacing">
  <div class="container">
    <header class="collection-header">
      <p class="eyebrow">{{ collection.products_count }} products</p>
      <h1>{{ collection.title | escape }}</h1>
      {% if collection.description != blank %}
        <div class="rte collection-description">{{ collection.description }}</div>
      {% endif %}
    </header>

    <form class="sort-form" method="get" action="{{ collection.url }}">
      <label for="SortBy-{{ section.id }}">Sort by</label>
      <select id="SortBy-{{ section.id }}" name="sort_by" data-sort-select>
        {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
        {% for option in collection.sort_options %}
          <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected="selected"{% endif %}>
            {{ option.name | escape }}
          </option>
        {% endfor %}
      </select>
    </form>

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="product-grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% else %}
          <p>No products found in this collection.</p>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="pagination" aria-label="Pagination">
          {% if paginate.previous %}
            <a class="button button-outline-dark" href="{{ paginate.previous.url }}">Previous</a>
          {% endif %}
          <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a class="button button-outline-dark" href="{{ paginate.next.url }}">Next</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Collection products",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
