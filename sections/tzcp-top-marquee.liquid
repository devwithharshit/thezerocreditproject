{{ 'tzcp-coming-soon.css' | asset_url | stylesheet_tag }}

<aside class="tzcp-coming-soon__marquee tzcp-coming-soon__marquee--top" aria-label="Relaunch phrases">
  <div class="tzcp-coming-soon__marquee-track">
    {% for repeat in (1..3) %}
      <span>SOMETHING IS COMING</span>
      <span>NOT MADE FOR EVERYONE</span>
      <span>ZERO CREDIT</span>
      <span>NO FULL REVEAL YET</span>
      <span>ENTER BEFORE THE NOISE</span>
      <span>THE NEXT VERSION IS LOADING</span>
      <span>BUILT IN THE DARK</span>
      <span>EARLY ACCESS ONLY</span>
    {% endfor %}
  </div>
</aside>

{% schema %}
{
  "name": "TZCP top marquee",
  "settings": []
}
{% endschema %}
