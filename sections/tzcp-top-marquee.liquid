{{ 'tzcp-coming-soon.css' | asset_url | stylesheet_tag }}

<aside class="tzcp-coming-soon__marquee tzcp-coming-soon__marquee--top" aria-label="Atmosphere phrases">
  <div class="tzcp-coming-soon__marquee-track">
    {% for repeat in (1..4) %}
      <span>SOMETHING IS COMING</span>
      <span>QUIET SIGNAL</span>
      <span>NOT FOR EVERYONE</span>
    {% endfor %}
  </div>
</aside>

{% schema %}
{
  "name": "Atmosphere marquee",
  "settings": []
}
{% endschema %}
