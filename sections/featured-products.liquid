{% assign featured_collection = section.settings.collection | default: collections['all'] %}
{% assign featured_products = featured_collection.products %}
{% if section.settings.sort_high_to_low %}
  {% assign featured_products = featured_products | sort: 'price' | reverse %}
{% endif %}
{% assign current_product_id = product.id %}
{% assign exclusion_terms = section.settings.excluded_keywords | downcase | split: ',' %}
{% assign is_product_signature = false %}
{% if request.page_type == 'product' %}
  {% assign is_product_signature = true %}
{% endif %}
{% assign filter_female_focused = section.settings.exclude_female_focused %}
{% assign include_female_focused = section.settings.include_one_female_focused %}
{% if is_product_signature %}
  {% assign filter_female_focused = true %}
  {% assign include_female_focused = true %}
{% endif %}
{% assign regular_products_limit = section.settings.products_to_show %}
{% if filter_female_focused and include_female_focused %}
  {% assign regular_products_limit = regular_products_limit | minus: 1 %}
{% endif %}

<section class="section-spacing featured-rail{% if request.page_type == 'product' %} featured-rail--product{% endif %}">
  <div class="container">
    <div class="section-heading" data-reveal>
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2>{{ section.settings.heading | escape }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>
      {% if featured_collection != blank and section.settings.show_view_all %}
        <a class="text-link" href="{{ featured_collection.url }}">View all</a>
      {% endif %}
    </div>

    {% if featured_products != blank %}
      <div class="product-grid product-grid--featured">
        {% assign products_shown = 0 %}
        {% for card_product in featured_products %}
          {% if request.page_type == 'product' and card_product.id == current_product_id %}
            {% continue %}
          {% endif %}

          {% if filter_female_focused %}
            {% assign card_product_tags = card_product.tags | join: ',' %}
            {% assign searchable_product_text = card_product.title | append: ',' | append: card_product_tags | downcase %}
            {% assign exclude_product = false %}
            {% for exclusion_term in exclusion_terms %}
              {% assign clean_exclusion_term = exclusion_term | strip %}
              {% if clean_exclusion_term != blank and searchable_product_text contains clean_exclusion_term %}
                {% assign exclude_product = true %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if exclude_product %}
              {% continue %}
            {% endif %}
          {% endif %}

          {% assign products_shown = products_shown | plus: 1 %}
          {% render 'product-card', product: card_product, index: products_shown %}
          {% if products_shown >= regular_products_limit %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if filter_female_focused and include_female_focused %}
          {% assign female_product = section.settings.female_product %}
          {% if is_product_signature %}
            {% if female_product == blank %}
              {% assign female_product = all_products['still-awake-baby-tee-light-pack'] %}
            {% endif %}
            {% if female_product == blank or female_product.id == current_product_id %}
              {% assign female_product = all_products['tzcp-after-hours-baby-tee'] %}
            {% endif %}
            {% if female_product == blank or female_product.id == current_product_id %}
              {% assign female_product = all_products['tzcp-late-night-drive-crop-top'] %}
            {% endif %}
          {% endif %}

          {% if female_product != blank and female_product.id != current_product_id %}
            {% assign products_shown = products_shown | plus: 1 %}
            {% render 'product-card', product: female_product, index: products_shown %}
          {% else %}
            {% for card_product in featured_products %}
              {% if request.page_type == 'product' and card_product.id == current_product_id %}
                {% continue %}
              {% endif %}

              {% assign card_product_tags = card_product.tags | join: ',' %}
              {% assign searchable_product_text = card_product.title | append: ',' | append: card_product_tags | downcase %}
              {% assign female_focused_product = false %}
              {% for exclusion_term in exclusion_terms %}
                {% assign clean_exclusion_term = exclusion_term | strip %}
                {% if clean_exclusion_term != blank and searchable_product_text contains clean_exclusion_term %}
                  {% assign female_focused_product = true %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% if female_focused_product %}
                {% assign products_shown = products_shown | plus: 1 %}
                {% render 'product-card', product: card_product, index: products_shown %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
      </div>
      {% if products_shown == 0 and request.design_mode %}
        <div class="editor-note">No products match this section's current filters.</div>
      {% endif %}
    {% elsif request.design_mode %}
      <div class="editor-note">Choose a collection in this section's settings to show real products.</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore / Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Current Drop"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Built for people starting from zero."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Uses All products when no collection is selected."
    },
    {
      "type": "checkbox",
      "id": "sort_high_to_low",
      "label": "Show highest-priced products first",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "exclude_female_focused",
      "label": "Exclude female-focused products",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "include_one_female_focused",
      "label": "Include one female-focused product",
      "info": "Adds one matching product after the regular filtered selection.",
      "default": false
    },
    {
      "type": "product",
      "id": "female_product",
      "label": "Female product to include",
      "info": "Shown as the final Signature Pieces card when female product inclusion is enabled."
    },
    {
      "type": "text",
      "id": "excluded_keywords",
      "label": "Excluded product keywords",
      "info": "Comma-separated keywords checked against product titles and tags.",
      "default": "women,female,baby tee,crop top,cropped,fitted"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
