{% assign featured_collection = section.settings.collection | default: collections['all'] %}
{% assign featured_products = featured_collection.products %}
{% if section.settings.sort_high_to_low %}
  {% assign featured_products = featured_products | sort: 'price' | reverse %}
{% endif %}

<section class="section-spacing featured-rail">
  <div class="container">
    <div class="section-heading" data-reveal>
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2>{{ section.settings.heading | escape }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>
      {% if featured_collection != blank and section.settings.show_view_all %}
        <a class="text-link" href="{{ featured_collection.url }}">View all</a>
      {% endif %}
    </div>

    {% if featured_products != blank %}
      <div class="product-grid product-grid--featured">
        {% for product in featured_products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product, index: forloop.index %}
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="editor-note">Choose a collection in this section's settings to show real products.</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore / Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Current Drop"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Built for people starting from zero."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Uses All products when no collection is selected."
    },
    {
      "type": "checkbox",
      "id": "sort_high_to_low",
      "label": "Show highest-priced products first",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
