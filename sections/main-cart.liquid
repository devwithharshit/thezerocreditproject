<section class="section-spacing">
  <div class="container narrow">
    <p class="eyebrow">TZCP / Relaunch</p>
    <h1>{{ section.settings.heading | escape }}</h1>
    <p>{{ section.settings.message | escape }}</p>
    <div class="button-row">
      <a class="button button-dark" href="{{ routes.root_url }}">Back to relaunch page</a>
      <a class="button button-outline-dark" href="/pages/contact">Contact</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cart is closed for relaunch"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "The Zero Credit Project is rebuilding. Shopping, cart, and checkout access will return with the relaunch."
    }
  ]
}
{% endschema %}
