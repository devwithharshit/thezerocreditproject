<section class="newsletter-section">
  <div class="container newsletter-inner">
    <div data-reveal>
      <p class="eyebrow">No spam. Just the project.</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      <p>{{ section.settings.subheading | escape }}</p>
    </div>

    {% form 'customer', class: 'newsletter-form', data-reveal: '', data-delay: '90' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">Email address</label>
      <div class="newsletter-fields">
        <input
          id="NewsletterEmail-{{ section.id }}"
          type="email"
          name="contact[email]"
          value="{{ form.email | escape }}"
          placeholder="Email address"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          maxlength="254"
          required
        >
        <button class="button button-light" type="submit">Join</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="form-message" tabindex="-1">Thanks for joining the project.</p>
      {% endif %}
      {% if form.errors %}
        <div class="form-message" role="alert">{{ form.errors | default_errors }}</div>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Editorial newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the list"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Be the first to know about new collections and drops."
    }
  ],
  "presets": [
    {
      "name": "Editorial newsletter"
    }
  ]
}
{% endschema %}
