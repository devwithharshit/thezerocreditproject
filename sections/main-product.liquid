{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_form_id = 'ProductForm-' | append: section.id %}

<section class="section-spacing product-page">
  <div class="container product-layout">
    <div class="product-gallery">
      {% if product.media.size > 0 %}
        {% for media in product.media %}
          <div class="product-media">
            {{
              media.preview_image
              | image_url: width: 1400
              | image_tag:
                widths: '500, 750, 1000, 1400',
                sizes: '(min-width: 900px) 58vw, 100vw',
                loading: 'lazy',
                alt: media.alt
            }}
          </div>
        {% endfor %}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="product-info">
      {% if product.vendor != blank %}
        <p class="eyebrow">{{ product.vendor | escape }}</p>
      {% endif %}
      <h1>{{ product.title | escape }}</h1>

      <div class="product-price">
        <span>{{ current_variant.price | money }}</span>
        {% if current_variant.compare_at_price > current_variant.price %}
          <s>{{ current_variant.compare_at_price | money }}</s>
        {% endif %}
      </div>

      {% form 'product', product, id: product_form_id, class: 'product-form' %}
        {% unless product.has_only_default_variant %}
          <label for="Variant-{{ section.id }}">Choose an option</label>
          <select id="Variant-{{ section.id }}" name="id">
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant == current_variant %}selected="selected"{% endif %}
                {% unless variant.available %}disabled="disabled"{% endunless %}
              >
                {{ variant.title | escape }} - {{ variant.price | money }}
                {% unless variant.available %} - Sold out{% endunless %}
              </option>
            {% endfor %}
          </select>
        {% else %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% endunless %}

        <label for="Quantity-{{ section.id }}">Quantity</label>
        <input id="Quantity-{{ section.id }}" class="quantity-input" type="number" name="quantity" value="1" min="1">

        <button
          class="button button-dark product-submit"
          type="submit"
          name="add"
          {% unless current_variant.available %}disabled="disabled"{% endunless %}
        >
          {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
        </button>

        {% if section.settings.show_dynamic_checkout and current_variant.available %}
          {{ form | payment_button }}
        {% endif %}
      {% endform %}

      {% if section.settings.shipping_note != blank %}
        <p class="product-note">{{ section.settings.shipping_note | escape }}</p>
      {% endif %}

      {% if product.description != blank %}
        <div class="rte product-description">{{ product.description }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_note",
      "label": "Shipping note",
      "default": "Made to order. Processing typically takes 1-5 business days."
    }
  ]
}
{% endschema %}
