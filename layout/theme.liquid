<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ 'zero-credit-favicon.png' | asset_url }}">
    <link rel="shortcut icon" type="image/png" href="{{ 'zero-credit-favicon.png' | asset_url }}">
    <link rel="apple-touch-icon" sizes="192x192" href="{{ 'zero-credit-favicon.png' | asset_url }}">

    <title>
      {{ page_title }}
      {% if current_tags %} - tagged "{{ current_tags | join: ', ' }}"{% endif %}
      {% if current_page != 1 %} - Page {{ current_page }}{% endif %}
      {% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <style>
      :root {
        --color-background: {{ settings.color_background }};
        --color-text: {{ settings.color_text }};
        --color-accent: {{ settings.color_accent }};
      }
    </style>
    {{ content_for_header }}
    {{ 'zero-credit.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'zero-credit.js' | asset_url }}" defer="defer"></script>
  </head>

  <body>
    <a class="skip-link" href="#MainContent">Skip to content</a>

    {% section 'tzcp-top-marquee' %}
    {% section 'header' %}

    {% capture rendered_content %}{{ content_for_layout }}{% endcapture %}
    {% if canonical_url contains '/policies/' %}
      {% capture rendered_content %}
        <section class="section-spacing not-found">
          <div class="container narrow">
            <p class="eyebrow">Relaunch</p>
            <h1>This page is hidden for now.</h1>
            <p>Return to home for early access.</p>
            <a class="button button-dark" href="{{ routes.root_url }}">Back to home</a>
          </div>
        </section>
      {% endcapture %}
    {% endif %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ rendered_content }}
    </main>

    {% section 'footer' %}
    {% section 'cart-drawer' %}
  </body>
</html>
